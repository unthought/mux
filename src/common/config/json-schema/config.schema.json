{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "projects": {
      "type": "array",
      "items": {
        "type": "array",
        "items": [
          {
            "type": "string"
          },
          {
            "type": "object",
            "properties": {
              "workspaces": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "path": {
                      "description": "Absolute path to workspace directory - REQUIRED for backward compatibility",
                      "type": "string"
                    },
                    "id": {
                      "description": "Stable workspace ID (10 hex chars for new workspaces) - optional for legacy",
                      "type": "string"
                    },
                    "name": {
                      "description": "Git branch / directory name (e.g., \"plan-a1b2\") - optional for legacy",
                      "type": "string"
                    },
                    "title": {
                      "description": "Human-readable workspace title (e.g., \"Fix plan mode over SSH\") - optional for legacy",
                      "type": "string"
                    },
                    "createdAt": {
                      "description": "ISO 8601 creation timestamp - optional for legacy",
                      "type": "string"
                    },
                    "aiSettingsByAgent": {
                      "description": "Per-agent workspace-scoped AI settings",
                      "type": "object",
                      "propertyNames": {
                        "type": "string",
                        "minLength": 1
                      },
                      "additionalProperties": {
                        "type": "object",
                        "properties": {
                          "model": {
                            "description": "Canonical model id in the form \"provider:model\"",
                            "type": "string"
                          },
                          "thinkingLevel": {
                            "description": "Thinking/reasoning effort level",
                            "type": "string",
                            "enum": ["off", "low", "medium", "high", "xhigh", "max"]
                          }
                        },
                        "required": ["model", "thinkingLevel"],
                        "additionalProperties": false
                      }
                    },
                    "runtimeConfig": {
                      "description": "Runtime configuration (local vs SSH) - optional, defaults to local",
                      "anyOf": [
                        {
                          "type": "object",
                          "properties": {
                            "type": {
                              "type": "string",
                              "const": "local"
                            },
                            "srcBaseDir": {
                              "description": "Base directory where all workspaces are stored (legacy worktree config)",
                              "type": "string"
                            },
                            "bgOutputDir": {
                              "description": "Directory for background process output (e.g., /tmp/mux-bashes)",
                              "type": "string"
                            }
                          },
                          "required": ["type", "srcBaseDir"],
                          "additionalProperties": false
                        },
                        {
                          "type": "object",
                          "properties": {
                            "type": {
                              "type": "string",
                              "const": "local"
                            },
                            "bgOutputDir": {
                              "description": "Directory for background process output (e.g., /tmp/mux-bashes)",
                              "type": "string"
                            }
                          },
                          "required": ["type"],
                          "additionalProperties": false
                        },
                        {
                          "type": "object",
                          "properties": {
                            "type": {
                              "type": "string",
                              "const": "worktree"
                            },
                            "srcBaseDir": {
                              "description": "Base directory where all workspaces are stored (e.g., ~/.mux/src)",
                              "type": "string"
                            },
                            "bgOutputDir": {
                              "description": "Directory for background process output (e.g., /tmp/mux-bashes)",
                              "type": "string"
                            }
                          },
                          "required": ["type", "srcBaseDir"],
                          "additionalProperties": false
                        },
                        {
                          "type": "object",
                          "properties": {
                            "type": {
                              "type": "string",
                              "const": "ssh"
                            },
                            "host": {
                              "description": "SSH host (can be hostname, user@host, or SSH config alias)",
                              "type": "string"
                            },
                            "srcBaseDir": {
                              "description": "Base directory on remote host where all workspaces are stored",
                              "type": "string"
                            },
                            "bgOutputDir": {
                              "description": "Directory for background process output (e.g., /tmp/mux-bashes)",
                              "type": "string"
                            },
                            "identityFile": {
                              "description": "Path to SSH private key (if not using ~/.ssh/config or ssh-agent)",
                              "type": "string"
                            },
                            "port": {
                              "description": "SSH port (default: 22)",
                              "type": "number"
                            },
                            "coder": {
                              "description": "Coder workspace configuration (when using Coder as SSH backend)",
                              "type": "object",
                              "properties": {
                                "workspaceName": {
                                  "description": "Coder workspace name",
                                  "type": "string"
                                },
                                "template": {
                                  "description": "Template used to create workspace",
                                  "type": "string"
                                },
                                "templateOrg": {
                                  "description": "Template organization (for disambiguation when templates have same name)",
                                  "type": "string"
                                },
                                "preset": {
                                  "description": "Preset used during creation",
                                  "type": "string"
                                },
                                "existingWorkspace": {
                                  "description": "True if connected to pre-existing Coder workspace",
                                  "type": "boolean"
                                }
                              },
                              "additionalProperties": false
                            }
                          },
                          "required": ["type", "host", "srcBaseDir"],
                          "additionalProperties": false
                        },
                        {
                          "type": "object",
                          "properties": {
                            "type": {
                              "type": "string",
                              "const": "docker"
                            },
                            "image": {
                              "description": "Docker image to use (e.g., node:20)",
                              "type": "string"
                            },
                            "containerName": {
                              "description": "Container name (populated after workspace creation)",
                              "type": "string"
                            },
                            "shareCredentials": {
                              "description": "Forward SSH agent and mount ~/.gitconfig read-only",
                              "type": "boolean"
                            }
                          },
                          "required": ["type", "image"],
                          "additionalProperties": false
                        },
                        {
                          "type": "object",
                          "properties": {
                            "type": {
                              "type": "string",
                              "const": "devcontainer"
                            },
                            "configPath": {
                              "description": "Path to devcontainer.json (relative to project root)",
                              "type": "string"
                            },
                            "shareCredentials": {
                              "description": "Forward SSH agent and mount ~/.gitconfig read-only",
                              "type": "boolean"
                            }
                          },
                          "required": ["type", "configPath"],
                          "additionalProperties": false
                        }
                      ]
                    },
                    "aiSettings": {
                      "description": "Workspace-scoped AI settings (model + thinking level)",
                      "type": "object",
                      "properties": {
                        "model": {
                          "description": "Canonical model id in the form \"provider:model\"",
                          "type": "string"
                        },
                        "thinkingLevel": {
                          "description": "Thinking/reasoning effort level",
                          "type": "string",
                          "enum": ["off", "low", "medium", "high", "xhigh", "max"]
                        }
                      },
                      "required": ["model", "thinkingLevel"],
                      "additionalProperties": false
                    },
                    "parentWorkspaceId": {
                      "description": "If set, this workspace is a child workspace spawned from the parent workspaceId (enables nesting in UI and backend orchestration).",
                      "type": "string"
                    },
                    "agentType": {
                      "description": "If set, selects an agent preset for this workspace (e.g., \"explore\" or \"exec\").",
                      "type": "string"
                    },
                    "agentId": {
                      "description": "If set, selects an agent definition for this workspace (e.g., \"explore\" or \"exec\").",
                      "type": "string"
                    },
                    "taskStatus": {
                      "description": "Agent task lifecycle status for child workspaces (queued|running|awaiting_report|interrupted|reported).",
                      "type": "string",
                      "enum": ["queued", "running", "awaiting_report", "interrupted", "reported"]
                    },
                    "reportedAt": {
                      "description": "ISO 8601 timestamp for when an agent task reported completion (optional).",
                      "type": "string"
                    },
                    "taskModelString": {
                      "description": "Model string used to run this agent task (used for restart-safe resumptions).",
                      "type": "string"
                    },
                    "taskThinkingLevel": {
                      "description": "Thinking level used for this agent task (used for restart-safe resumptions).",
                      "type": "string",
                      "enum": ["off", "low", "medium", "high", "xhigh", "max"]
                    },
                    "taskPrompt": {
                      "description": "Initial prompt for a queued agent task (persisted only until the task actually starts).",
                      "type": "string"
                    },
                    "taskExperiments": {
                      "description": "Experiments inherited from parent for restart-safe resumptions.",
                      "type": "object",
                      "properties": {
                        "programmaticToolCalling": {
                          "type": "boolean"
                        },
                        "programmaticToolCallingExclusive": {
                          "type": "boolean"
                        },
                        "execSubagentHardRestart": {
                          "type": "boolean"
                        }
                      },
                      "additionalProperties": false
                    },
                    "taskBaseCommitSha": {
                      "description": "Git commit SHA this agent task workspace started from (used for generating git-format-patch artifacts).",
                      "type": "string"
                    },
                    "taskTrunkBranch": {
                      "description": "Trunk branch used to create/init this agent task workspace (used for restart-safe init on queued tasks).",
                      "type": "string"
                    },
                    "mcp": {
                      "description": "LEGACY: Per-workspace MCP overrides (migrated to <workspace>/.mux/mcp.local.jsonc)",
                      "type": "object",
                      "properties": {
                        "disabledServers": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "enabledServers": {
                          "type": "array",
                          "items": {
                            "type": "string"
                          }
                        },
                        "toolAllowlist": {
                          "type": "object",
                          "propertyNames": {
                            "type": "string"
                          },
                          "additionalProperties": {
                            "type": "array",
                            "items": {
                              "type": "string"
                            }
                          }
                        }
                      },
                      "additionalProperties": false
                    },
                    "archivedAt": {
                      "description": "ISO 8601 timestamp when workspace was last archived. Workspace is considered archived if archivedAt > unarchivedAt (or unarchivedAt is absent).",
                      "type": "string"
                    },
                    "unarchivedAt": {
                      "description": "ISO 8601 timestamp when workspace was last unarchived. Used for recency calculation to bump restored workspaces to top.",
                      "type": "string"
                    },
                    "sectionId": {
                      "description": "ID of the section this workspace belongs to (optional, unsectioned if absent)",
                      "type": "string"
                    }
                  },
                  "required": ["path"],
                  "additionalProperties": false
                }
              },
              "sections": {
                "description": "Sections for organizing workspaces within this project",
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "description": "Unique section ID (8 hex chars)",
                      "type": "string"
                    },
                    "name": {
                      "description": "Display name for the section",
                      "type": "string"
                    },
                    "color": {
                      "description": "Accent color (hex value like #ff6b6b or preset name)",
                      "type": "string"
                    },
                    "nextId": {
                      "description": "ID of the next section in display order (null = last, undefined treated as null)",
                      "anyOf": [
                        {
                          "type": "string"
                        },
                        {
                          "type": "null"
                        }
                      ]
                    }
                  },
                  "required": ["id", "name"],
                  "additionalProperties": false
                }
              },
              "idleCompactionHours": {
                "description": "Hours of inactivity before auto-compacting workspaces. null/undefined = disabled.",
                "anyOf": [
                  {
                    "type": "number",
                    "minimum": 1
                  },
                  {
                    "type": "null"
                  }
                ]
              },
              "runtimeEnablement": {
                "description": "Runtime enablement overrides (store `false` only to keep config.json minimal)",
                "type": "object",
                "properties": {
                  "local": {
                    "type": "boolean",
                    "const": false
                  },
                  "worktree": {
                    "type": "boolean",
                    "const": false
                  },
                  "ssh": {
                    "type": "boolean",
                    "const": false
                  },
                  "coder": {
                    "type": "boolean",
                    "const": false
                  },
                  "docker": {
                    "type": "boolean",
                    "const": false
                  },
                  "devcontainer": {
                    "type": "boolean",
                    "const": false
                  }
                },
                "additionalProperties": false
              },
              "runtimeOverridesEnabled": {
                "description": "Whether this project uses runtime overrides, even if no overrides are set",
                "type": "boolean"
              },
              "defaultRuntime": {
                "description": "Default runtime override for new workspaces in this project",
                "type": "string",
                "enum": ["local", "worktree", "ssh", "coder", "docker", "devcontainer"]
              }
            },
            "required": ["workspaces"],
            "additionalProperties": false
          }
        ]
      }
    },
    "apiServerBindHost": {
      "type": "string"
    },
    "apiServerPort": {
      "type": "number"
    },
    "apiServerServeWebUi": {
      "type": "boolean"
    },
    "mdnsAdvertisementEnabled": {
      "type": "boolean"
    },
    "mdnsServiceName": {
      "type": "string"
    },
    "serverSshHost": {
      "type": "string"
    },
    "serverAuthGithubOwner": {
      "type": "string"
    },
    "defaultProjectDir": {
      "type": "string"
    },
    "viewedSplashScreens": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "featureFlagOverrides": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "string",
        "enum": ["default", "on", "off"]
      }
    },
    "layoutPresets": {},
    "taskSettings": {
      "type": "object",
      "properties": {
        "maxParallelAgentTasks": {
          "type": "integer",
          "minimum": 1,
          "maximum": 256
        },
        "maxTaskNestingDepth": {
          "type": "integer",
          "minimum": 1,
          "maximum": 5
        },
        "proposePlanImplementReplacesChatHistory": {
          "type": "boolean"
        },
        "planSubagentExecutorRouting": {
          "type": "string",
          "enum": ["exec", "orchestrator", "auto"]
        },
        "planSubagentDefaultsToOrchestrator": {
          "type": "boolean"
        },
        "bashOutputCompactionMinLines": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1000
        },
        "bashOutputCompactionMinTotalBytes": {
          "type": "integer",
          "minimum": 0,
          "maximum": 16384
        },
        "bashOutputCompactionMaxKeptLines": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        },
        "bashOutputCompactionTimeoutMs": {
          "type": "integer",
          "minimum": 1000,
          "maximum": 120000
        },
        "bashOutputCompactionHeuristicFallback": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "muxGatewayEnabled": {
      "type": "boolean"
    },
    "muxGatewayModels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "defaultModel": {
      "type": "string"
    },
    "hiddenModels": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "preferredCompactionModel": {
      "type": "string"
    },
    "agentAiDefaults": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64,
        "pattern": "^[a-z0-9]+(?:[a-z0-9_-]*[a-z0-9])?$"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "modelString": {
            "type": "string"
          },
          "thinkingLevel": {
            "type": "string",
            "enum": ["off", "low", "medium", "high", "xhigh", "max"]
          },
          "enabled": {
            "type": "boolean"
          }
        },
        "additionalProperties": false
      }
    },
    "subagentAiDefaults": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64,
        "pattern": "^[a-z0-9]+(?:[a-z0-9_-]*[a-z0-9])?$"
      },
      "additionalProperties": {
        "type": "object",
        "properties": {
          "modelString": {
            "type": "string"
          },
          "thinkingLevel": {
            "type": "string",
            "enum": ["off", "low", "medium", "high", "xhigh", "max"]
          }
        },
        "additionalProperties": false
      }
    },
    "useSSH2Transport": {
      "type": "boolean"
    },
    "muxGovernorUrl": {
      "type": "string"
    },
    "muxGovernorToken": {
      "type": "string"
    },
    "stopCoderWorkspaceOnArchive": {
      "type": "boolean"
    },
    "terminalDefaultShell": {
      "type": "string"
    },
    "updateChannel": {
      "type": "string",
      "enum": ["stable", "nightly"]
    },
    "runtimeEnablement": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "enum": ["local", "worktree", "ssh", "coder", "docker", "devcontainer"]
      },
      "additionalProperties": {
        "type": "boolean",
        "const": false
      }
    },
    "defaultRuntime": {
      "type": "string",
      "enum": ["local", "worktree", "ssh", "coder", "docker", "devcontainer"]
    }
  },
  "additionalProperties": {}
}
